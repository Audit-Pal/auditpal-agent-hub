// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  BOUNTY_HUNTER
  ORGANIZATION
  ADMIN
  GATEKEEPER
  VALIDATOR
}

enum ProgramStatus {
  DRAFT
  AWAITING_FUNDS
  ACTIVE
  PAUSED
  CLOSED
}

enum ProgramKind {
  BUG_BOUNTY
  CROWDSOURCED_AUDIT
  ATTACK_SIMULATION
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ProgramCategory {
  WEB
  SMART_CONTRACT
  APPS
  BLOCKCHAIN
}

enum PlatformTag {
  ETHEREUM
  ARBITRUM
  BASE
  MONAD
  SUI
  SOLANA
  OFFCHAIN
}

enum ProgrammingLanguage {
  SOLIDITY
  RUST
  TYPESCRIPT
  SWIFT
  GO
  MOVE
}

enum ScopeEnvironment {
  MAINNET
  TESTNET
  PRODUCTION
  STAGING
  OFFCHAIN
  AUDIT
}

enum ScopeReferenceKind {
  SOURCE_FILE
  GITHUB_REPO
  GITHUB_ORG
  GITHUB_PROFILE
  CONTRACT_ADDRESS
  PACKAGE
  SERVICE
  RUNBOOK
  DOMAIN
}

enum ReportStatus {
  SUBMITTED
  NEEDS_INFO
  TRIAGED
  DUPLICATE
  REJECTED
  RESOLVED
  LOW_EFFORT
  AI_TRIAGE_PENDING
  AI_TRIAGED
  ESCALATED
  ACCEPTED
  CLOSED
}

enum ReportSource {
  CROWD_REPORT
  EXPLOIT_FEED
  AGENT_DISAGREEMENT
}

enum VulnerabilityStatus {
  PENDING
  ESCALATED
  ACCEPTED
  REJECTED
  DUPLICATE
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  passwordHash      String
  name              String
  role              Role           @default(BOUNTY_HUNTER)
  reputation        Int            @default(0)
  bio               String?
  avatarUrl         String?
  githubHandle      String?
  /// For ORGANIZATION role — the company/org name using Agent-as-a-service
  organizationName  String?
  apiKeyHash        String?        @unique
  apiKeyPreview     String?
  apiKeyCreatedAt   DateTime?
  apiKeyLastUsedAt  DateTime?
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relations
  reports           Report[]
  refreshTokens     RefreshToken[]
  ownedPrograms     Program[]      @relation("ProgramOwner")
  gatekeptPrograms  Program[]      @relation("ProgramGatekeeper")
  validatedPrograms Program[]      @relation("ProgramValidator")
  ownedAgents       Agent[]        @relation("AgentOwner")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// PROGRAMS
// ─────────────────────────────────────────────

model Program {
  id               String      @id
  code             String      @unique
  name             String
  status           ProgramStatus @default(DRAFT)
  company          String
  kind             ProgramKind
  tagline          String
  description      String      @db.Text
  accentTone       String      @default("mint")
  logoMark         String
  isNew            Boolean     @default(false)
  triagedLabel     String      @default("Triaged by AuditPal AI + Human Ops")
  maxBountyUsd     Int
  paidUsd          Int         @default(0)
  scopeReviews     Int         @default(0)
  isPublished      Boolean     @default(true)
  startedAt        DateTime
  publishedAt      DateTime?
  updatedAt        DateTime    @updatedAt
  createdAt        DateTime    @default(now())

  // Owner (organization)
  ownerId          String?
  owner            User?       @relation("ProgramOwner", fields: [ownerId], references: [id])

  gatekeeperId     String?
  gatekeeper       User?       @relation("ProgramGatekeeper", fields: [gatekeeperId], references: [id])

  validatorId      String?
  validator        User?       @relation("ProgramValidator", fields: [validatorId], references: [id])

  // Header / policy config (1-1 embedded as JSON cols for simplicity)
  reputationRequired Int       @default(0)
  pocRequired        Boolean   @default(true)
  liveMessage        String    @default("Live program is active now")
  responseSla        String
  payoutCurrency     String    @default("USDC")
  payoutWindow       String
  duplicatePolicy    String    @db.Text
  disclosureModel    String    @db.Text

  // Relation arrays
  categories          ProgramCategory[]
  platforms           PlatformTag[]
  languages           ProgrammingLanguage[]
  summaryHighlights   String[]
  submissionChecklist String[]

  // One-to-many relations
  rewardTiers         RewardTier[]
  scopeTargets        ScopeTarget[]
  triageStages        TriageStage[]
  policySections      PolicySection[]
  reportQueue         Report[]
  evidenceFields      EvidenceField[]
  linkedAgents        ProgramAgentLink[]

  @@map("programs")
}

model RewardTier {
  id             String    @id @default(cuid())
  programId      String
  severity       Severity
  maxRewardUsd   Int
  triageSla      String
  payoutWindow   String
  examples       String[]

  program        Program   @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, severity])
  @@map("reward_tiers")
}

model ScopeTarget {
  id             String              @id @default(cuid())
  programId      String
  label          String
  location       String
  assetType      String
  severity       Severity
  reviewStatus   String
  note           String              @db.Text
  referenceKind  ScopeReferenceKind?
  referenceValue String?
  referenceUrl   String?
  network        String?
  environment    ScopeEnvironment?
  tags           String[]
  sourceCode     String?             @db.Text

  program        Program             @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("scope_targets")
}

model TriageStage {
  id          String   @id @default(cuid())
  programId   String
  order       Int
  title       String
  owner       String
  automation  String
  trigger     String   @db.Text
  outputs     String[]
  humanGate   String   @db.Text

  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("triage_stages")
}

model PolicySection {
  id        String   @id @default(cuid())
  programId String
  order     Int
  title     String
  items     String[]

  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("policy_sections")
}

model EvidenceField {
  id          String  @id @default(cuid())
  programId   String
  name        String
  description String  @db.Text

  program     Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("evidence_fields")
}

// ─────────────────────────────────────────────
// REPORTS (Researcher Submissions)
// ─────────────────────────────────────────────

model Report {
  id              String       @id @default(cuid())
  /// Human-readable ID like "AP-1021-R001"
  humanId         String       @unique
  programId       String
  reporterId      String?
  reporterName    String
  title           String       // Title of the overall submission
  status          ReportStatus @default(SUBMITTED)
  source          ReportSource @default(CROWD_REPORT)
  route           String       @default("Standard intake queue")
  decisionOwner   String?
  rewardEstimateUsd Int?
  responseSla     String?
  nextAction      String?
  note            String?      @db.Text

  structuredData  Json?        // For future Knowledge Graph construction

  // New triage fields
  aiScore         Float?
  aiSummary       String?      @db.Text

  submittedAt     DateTime     @default(now())
  resolvedAt      DateTime?
  updatedAt       DateTime     @updatedAt

  program         Program      @relation(fields: [programId], references: [id])
  reporter        User?        @relation(fields: [reporterId], references: [id])

  vulnerabilities Vulnerability[]

  @@index([programId])
  @@index([reporterId])
  @@index([status])
  @@map("reports")
}

model Vulnerability {
  id              String       @id @default(cuid())
  reportId        String
  title           String
  severity        Severity
  target          String
  summary         String       @db.Text
  impact          String       @db.Text
  proof           String       @db.Text
  codeSnippet     String?      @db.Text
  errorLocation   String?      @db.Text
  
  status          VulnerabilityStatus @default(PENDING)
  validationDecision String?   // 'ACCEPT', 'REJECT', 'ESCALATE'
  validationNotes String?      @db.Text
  rewardPaidUsd   Int?
  rewardTxHash    String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  report          Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("vulnerabilities")
}

// ─────────────────────────────────────────────
// AGENTS (AI Triage Agents)
// ─────────────────────────────────────────────

model Agent {
  id                     String              @id
  slug                   String?             @unique
  name                   String
  accentTone             String              @default("mint")
  logoMark               String
  rank                   Int?
  score                  Float?
  minerName              String?
  validatorScore         Float?
  headline               String
  summary                String              @db.Text
  capabilities           String[]
  supportedTechnologies  String[]
  guardrails             String[]
  supportedSurfaces      ProgramCategory[]
  isActive               Boolean             @default(true)
  ownerId                String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  // Relations
  owner                  User?               @relation("AgentOwner", fields: [ownerId], references: [id])
  metrics                AgentMetric[]
  tools                  AgentTool[]
  runtimeFlow            AgentStage[]
  outputSchema           AgentOutputField[]
  recentExecutions       AgentExecution[]
  linkedPrograms         ProgramAgentLink[]

  @@map("agents")
}

model AgentMetric {
  id        String @id @default(cuid())
  agentId   String
  label     String
  value     String
  note      String

  agent     Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_metrics")
}

model AgentTool {
  id      String  @id @default(cuid())
  agentId String
  name    String
  access  String?
  useCase String  @db.Text

  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_tools")
}

model AgentStage {
  id          String   @id @default(cuid())
  agentId     String
  order       Int
  title       String
  description String   @db.Text
  outputs     String[]
  humanGate   String?

  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_stages")
}

model AgentOutputField {
  id          String @id @default(cuid())
  agentId     String
  name        String
  type        String
  description String @db.Text

  agent       Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_output_fields")
}

model AgentExecution {
  id        String   @id @default(cuid())
  agentId   String
  programId String?
  title     String
  status    String?
  summary   String   @db.Text
  timestamp DateTime

  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_executions")
}

// Junction: Program ↔ Agent
model ProgramAgentLink {
  id        String  @id @default(cuid())
  programId String
  agentId   String
  purpose   String  @db.Text
  trigger   String  @db.Text
  output    String  @db.Text

  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  agent     Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([programId, agentId])
  @@map("program_agent_links")
}
